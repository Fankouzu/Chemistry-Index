# Copy to keystore.properties (gitignored) for release signing.
# Put release.keystore in the android/ directory (same folder as keystore.properties).
# keytool -genkey -v -keystore release.keystore -alias chemistry -keyalg RSA -keysize 2048 -validity 10000
storeFile=release.keystore
storePassword=your_store_password
keyAlias=chemistry
keyPassword=your_key_password
